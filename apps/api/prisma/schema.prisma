// StockPilot — multi-tenant inventory & POS data model
// PostgreSQL + Prisma. Every business-owned row carries businessId for tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  STAFF
}

enum MovementType {
  IN // restock / purchase
  OUT // sale / loss
  ADJUST // manual correction
}

/// A tenant. All data is scoped to a Business.
model Business {
  id        String   @id @default(cuid())
  name      String
  currency  String   @default("USD")
  createdAt DateTime @default(now())

  users     User[]
  products  Product[]
  suppliers Supplier[]
  customers Customer[]
  sales     Sale[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  sales      Sale[]

  @@index([businessId])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  rating    Int      @default(0) // 0–5
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  products   Product[]

  @@index([businessId])
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  email      String?
  phone      String?
  totalSpent Decimal  @default(0) @db.Decimal(12, 2)
  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  sales      Sale[]

  @@index([businessId])
}

model Product {
  id        String   @id @default(cuid())
  name      String
  sku       String
  barcode   String?
  category  String?
  costPrice Decimal  @default(0) @db.Decimal(12, 2)
  salePrice Decimal  @default(0) @db.Decimal(12, 2)
  stock     Int      @default(0)
  minStock  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  supplier   Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierId String?
  saleItems  SaleItem[]
  movements  StockMovement[]

  @@unique([businessId, sku]) // SKU unique within a business
  @@index([businessId])
}

model Sale {
  id        String   @id @default(cuid())
  total     Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessId String
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?
  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  userId     String
  items      SaleItem[]

  @@index([businessId])
  @@index([createdAt])
}

model SaleItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)

  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleId    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId String

  @@index([saleId])
}

/// Append-only audit trail of every stock change.
model StockMovement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@index([productId])
}

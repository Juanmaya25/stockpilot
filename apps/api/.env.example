# PostgreSQL (matches docker-compose.yml: host port 5433 -> container 5432)
DATABASE_URL="postgresql://stockpilot:stockpilot@localhost:5433/stockpilot?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too-another-long-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# AI assistant — Groq (free, OpenAI-compatible). Get a free key at console.groq.com
GROQ_API_KEY=""
AI_MODEL="llama-3.3-70b-versatile"

# Stripe (test mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Server
PORT=3000
WEB_ORIGIN="http://localhost:3001"
